# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/franchiseen_platform"
DATABASE_POOL_SIZE=20

# Redis Configuration
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# API Configuration
API_PORT=3001
API_HOST="localhost"
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000,http://localhost:3002,http://localhost:3003"

# File Storage (AWS S3 or compatible)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET="franchiseen-uploads"
AWS_S3_ENDPOINT="" # For S3-compatible services like MinIO

# Email Configuration (SendGrid, Mailgun, etc.)
EMAIL_PROVIDER="sendgrid" # sendgrid, mailgun, smtp
EMAIL_API_KEY=""
EMAIL_FROM="noreply@franchiseen.com"
EMAIL_FROM_NAME="Franchiseen"

# SMTP Configuration (if using SMTP)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE=false

# Payment Gateways
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""

# Solana Pay Configuration
SOLANA_NETWORK="devnet" # mainnet-beta, devnet, testnet
SOLANA_RPC_URL="" # Optional: custom RPC URL
SOLANA_MERCHANT_WALLET="" # Your merchant wallet address
SOLANA_PRIVATE_KEY="" # Base64 encoded private key (optional, for advanced features)
SOLANA_WEBHOOK_SECRET="" # Secret for webhook validation

# Platform Configuration
PLATFORM_NAME="Franchiseen"
PLATFORM_DOMAIN="franchiseen.com"
PLATFORM_SUPPORT_EMAIL="support@franchiseen.com"

# Frontend URLs
ADMIN_DASHBOARD_URL="http://localhost:3000"
STORE_DASHBOARD_URL="http://localhost:3002"
STOREFRONT_BASE_URL="http://localhost:3003"

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring and Logging
LOG_LEVEL="info" # error, warn, info, debug
SENTRY_DSN=""

# Development
ENABLE_SWAGGER=true
ENABLE_GRAPHQL_PLAYGROUND=true
